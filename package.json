{
	"name": "tedger",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"deploy": "wrangler deploy",
		"dev": "wrangler dev",
		"start": "wrangler dev",
		"test": "vitest",
		"db:generate": "wrangler d1 execute tedger --local --generate-schema",
		"db:push": "wrangler d1 execute tedger --local --file ./migrations/schema.sql",
		"db:migrate": "wrangler d1 execute tedger --remote --file ./migrations/schema.sql",
		"types": "wrangler types"
	},
	"dependencies": {
		"@cloudflare/workers-types": "^4.20241231.0",
		"@grammyjs/types": "^3.16.0",
		"drizzle-orm": "^0.38.3",
		"effect": "^3.10.16",
		"grammy": "^1.30.0"
	},
	"devDependencies": {
		"@cloudflare/vitest-pool-workers": "^0.12.4",
		"drizzle-kit": "^0.30.1",
		"typescript": "^5.7.2",
		"vitest": "~3.2.0",
		"wrangler": "^4.72.0"
	}
}
